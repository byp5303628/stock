<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ethanpark.stock.common.dal.mappers.MetadataEnumMapper">
    <resultMap id="BaseResultMap" type="com.ethanpark.stock.common.dal.mappers.entity.MetadataEnumDO">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <result column="name" jdbcType="VARCHAR" property="name"/>
        <result column="code" jdbcType="VARCHAR" property="code"/>
        <result column="description" jdbcType="VARCHAR" property="description"/>
        <result column="status" jdbcType="VARCHAR" property="status"/>
        <result column="gmt_create" jdbcType="TIMESTAMP" property="gmtCreate"/>
        <result column="gmt_modified" jdbcType="TIMESTAMP" property="gmtModified"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        select *
        from metadata_enum
        where status != 'DELETED'
        order by gmt_modified desc
    </select>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select *
        from metadata_enum
        where id = #{id}
    </select>

    <select id="selectByCode" parameterType="java.lang.String" resultMap="BaseResultMap">
        select *
        from metadata_enum
        where code = #{code}
    </select>

    <insert id="insert" parameterType="com.ethanpark.stock.common.dal.mappers.entity.MetadataEnumDO" useGeneratedKeys="true" keyProperty="id">
        insert into metadata_enum (name, code, description, status, gmt_create, gmt_modified)
        values (#{name}, #{code}, #{description}, #{status}, now(), now())
    </insert>

    <update id="updateById" parameterType="com.ethanpark.stock.common.dal.mappers.entity.MetadataEnumDO">
        update metadata_enum
        set name        = #{name}
          , code        = #{code}
          , description = #{description}
          , status      = #{status}
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from metadata_enum
        where id = #{id}
    </delete>
</mapper>
