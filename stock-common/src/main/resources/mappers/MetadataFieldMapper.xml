<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ethanpark.stock.common.dal.mappers.MetadataFieldMapper">
    <resultMap id="BaseResultMap" type="com.ethanpark.stock.common.dal.mappers.entity.MetadataFieldDO">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <result column="model_id" jdbcType="BIGINT" property="modelId"/>
        <result column="field_name" jdbcType="VARCHAR" property="fieldName"/>
        <result column="field_type" jdbcType="VARCHAR" property="fieldType"/>
        <result column="business_meaning" jdbcType="VARCHAR" property="businessMeaning"/>
        <result column="required" jdbcType="INTEGER" property="required"/>
        <result column="constraints" jdbcType="VARCHAR" property="constraints"/>
        <result column="enum_id" jdbcType="BIGINT" property="enumId"/>
        <result column="sort_order" jdbcType="INTEGER" property="sortOrder"/>
        <result column="ext_info" jdbcType="VARCHAR" property="extInfo"/>
        <result column="gmt_create" jdbcType="TIMESTAMP" property="gmtCreate"/>
        <result column="gmt_modified" jdbcType="TIMESTAMP" property="gmtModified"/>
    </resultMap>

    <select id="selectByModelId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select *
        from metadata_field
        where model_id = #{modelId}
        order by sort_order asc
    </select>

    <select id="selectByEnumId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select *
        from metadata_field
        where enum_id = #{enumId}
    </select>

    <!-- C3: 批量查询消除 N+1 -->
    <select id="selectByEnumIds" resultMap="BaseResultMap">
        select *
        from metadata_field
        where enum_id in
        <foreach collection="list" item="enumId" open="(" separator="," close=")">
            #{enumId}
        </foreach>
    </select>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select *
        from metadata_field
        where id = #{id}
    </select>

    <insert id="insert" parameterType="com.ethanpark.stock.common.dal.mappers.entity.MetadataFieldDO" useGeneratedKeys="true" keyProperty="id">
        insert into metadata_field (model_id, field_name, field_type, business_meaning, required, constraints, enum_id, sort_order, ext_info, gmt_create, gmt_modified)
        values (#{modelId}, #{fieldName}, #{fieldType}, #{businessMeaning}, #{required}, #{constraints}, #{enumId}, #{sortOrder}, #{extInfo}, now(), now())
    </insert>

    <update id="updateById" parameterType="com.ethanpark.stock.common.dal.mappers.entity.MetadataFieldDO">
        update metadata_field
        set model_id         = #{modelId}
          , field_name       = #{fieldName}
          , field_type       = #{fieldType}
          , business_meaning = #{businessMeaning}
          , required         = #{required}
          , constraints      = #{constraints}
          , enum_id          = #{enumId}
          , sort_order       = #{sortOrder}
          , ext_info         = #{extInfo}
        where id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from metadata_field
        where id = #{id}
    </delete>

    <delete id="deleteByModelId" parameterType="java.lang.Long">
        delete from metadata_field
        where model_id = #{modelId}
    </delete>
</mapper>
